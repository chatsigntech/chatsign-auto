# ChatSign Orchestrator Environment Configuration

# Database
DATABASE_URL=sqlite:///./data/chatsign/orchestrator/tasks.db

# Security (MUST change in production)
SECRET_KEY=change-this-to-a-random-secret-key
DEFAULT_ADMIN_PASSWORD=admin123

# External project paths (adjust to local paths)
UNISIGN_PATH=./UniSignMimicTurbo
GLOSS_AWARE_PATH=./gloss_aware
PSEUDO_GLOSS_PATH=./pseudo-gloss-English
CHATSIGN_ACCURACY_URL=https://localhost:5443
SPAMO_SEGMENT_PATH=./spamo_segement

# Shared data directory
SHARED_DATA_ROOT=./data/chatsign/shared

# GPU configuration
MAX_GPUS=1
CUDA_VISIBLE_DEVICES=0

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/orchestrator.log

# API configuration
API_HOST=0.0.0.0
API_PORT=8000
